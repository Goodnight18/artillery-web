{
  "firestore": {
    "database": "(default)",
    "location": "asia-southeast3",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix functions run build"
    ]
  },

  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "asia-east1"
    }
  }
}
